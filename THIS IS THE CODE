const int ledPin = 9;

void setup() {
  pinMode(ledPin, OUTPUT);
  randomSeed(analogRead(0));
}

void loop() {

  int baseBrightness = 180;       // steady flame glow
  int flicker = random(-80, 60);  // random flame variation
  
  int brightness = baseBrightness + flicker;
  
  brightness = constrain(brightness, 0, 255);

  analogWrite(ledPin, brightness);

  delay(random(30, 120));  // irregular flicker timing
}
